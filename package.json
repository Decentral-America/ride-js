{
  "author": "DecentralChain",
  "bugs": {
    "url": "https://github.com/Decentral-America/ride-js/issues"
  },
  "dependencies": {
    "@decentralchain/ts-lib-crypto": "^2.0.1",
    "@waves/ride-lang": "1.6.1",
    "@waves/ride-repl": "1.6.1"
  },
  "description": "JS compiler for Ride - the smart-contract language for DecentralChain",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.7",
    "@evilmartians/lefthook": "2.1.3",
    "@size-limit/preset-small-lib": "12.0.0",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsdown": "0.21.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/ride-js#readme",
  "keywords": [
    "decentralchain",
    "dcc",
    "blockchain",
    "ride",
    "compiler",
    "smart-contracts",
    "decentralchain-sdk",
    "ride-language",
    "decompile",
    "ride-compiler"
  ],
  "license": "MIT",
  "module": "./dist/index.mjs",
  "name": "@decentralchain/ride-js",
  "packageManager": "npm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/ride-js.git"
  },
  "scripts": {
    "build": "tsdown",
    "bulletproof": "biome check --write . && npm run typecheck && npm run test",
    "bulletproof:check": "biome check . && npm run typecheck && npm run test",
    "check:exports": "attw --pack . --profile esm-only",
    "check:publint": "publint",
    "check:size": "size-limit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "postpublish": "git push",
    "postversion": "npm publish",
    "prepack": "npm run build",
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "npm audit --audit-level=high && npm run lint:check && npm run typecheck && npm run test && npm run build && npm run check:publint && npm run check:exports && npm run check:size"
  },
  "sideEffects": true,
  "size-limit": [
    {
      "ignore": [
        "@waves/ride-lang",
        "@waves/ride-repl",
        "@decentralchain/ts-lib-crypto"
      ],
      "limit": "10 kB",
      "path": "./dist/index.mjs"
    }
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "2.3.1"
}
